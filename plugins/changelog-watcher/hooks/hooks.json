{
  "_description": "Changelog Watcher - research tracking (delegated to @fusengine/harness)",

  "hooks": {
    "PostToolUse": [
      {
        "_description": "Harness: track Exa/WebFetch/WebSearch research into ~/.claude/logs/00-changelog state (ports track-watch-research.py)",
        "matcher": "mcp__.*exa|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/plugins/marketplaces/fusengine-plugins/plugins/node_modules/@fusengine/harness/dist/cli/bin.mjs hook claude-code changelog"
          }
        ]
      }
    ]
  }
}
